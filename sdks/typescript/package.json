{
  "name": "crdtsync",
  "version": "0.0.0",
  "description": "crdtsync TypeScript SDK — client for the self-hosted collaborative sync engine",
  "license": "AGPL-3.0-or-later",
  "homepage": "https://crdtsync.com",
  "bugs": {
    "url": "https://github.com/faiscadev/crdtsync/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/faiscadev/crdtsync.git",
    "directory": "sdks/typescript"
  },
  "author": "Lucas Vieira <vieiralucas4@gmail.com>",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
